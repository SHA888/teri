# LLM provider (OpenAI-compatible endpoint)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o

# Embedding model
EMBED_MODEL=text-embedding-3-small

# Simulation defaults
DEFAULT_AGENT_COUNT=100
SIM_MAX_TICKS=50
SIM_PARALLELISM=8

# Persistence
MEMORY_DB_PATH=./data/memory.db
GRAPH_DB_PATH=./data/graph

# API server
BIND_ADDR=0.0.0.0:8080

# Logging
RUST_LOG=teri=debug,tower_http=info
