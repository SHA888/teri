# ============================================================================
# LLM Provider Configuration
# ============================================================================
# Teri supports multiple LLM providers via adapters. Choose one below.

# --- OpenAI Adapter (OpenAI-compatible APIs) ---
# Works with: OpenAI, Ollama, LM Studio, vLLM, Together AI, Groq, etc.
# Examples:
#   OpenAI:     https://api.openai.com/v1
#   Ollama:     http://localhost:11434/v1
#   LM Studio:  http://localhost:1234/v1
#   Together:   https://api.together.xyz/v1
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o

# --- Anthropic Adapter (Claude) ---
# Uncomment to use Anthropic Claude instead
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-3-5-sonnet-20241022

# --- Google Gemini Adapter ---
# Uncomment to use Google Gemini instead
# LLM_PROVIDER=gemini
# LLM_API_KEY=AIza...
# LLM_MODEL=gemini-1.5-pro

# Embedding model (for future vector search)
EMBED_MODEL=text-embedding-3-small

# Simulation defaults
DEFAULT_AGENT_COUNT=100
SIM_MAX_TICKS=50
SIM_PARALLELISM=8

# Persistence
MEMORY_DB_PATH=./data/memory.db
GRAPH_DB_PATH=./data/graph

# API server
BIND_ADDR=0.0.0.0:8080

# Logging
RUST_LOG=teri=debug,tower_http=info
